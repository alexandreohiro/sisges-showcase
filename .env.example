SISGES_ENV=dev
SISGES_DEBUG=true
SISGES_DATABASE_URL=sqlite:///data/sisges.db
# MySQL homolog/prod example. Do not commit real credentials.
# SISGES_DATABASE_URL=mysql+pymysql://sisges_app:${SISGES_MYSQL_PASSWORD}@127.0.0.1:3306/sisges?charset=utf8mb4
SISGES_DATABASE_ECHO=false
SISGES_DATABASE_POOL_SIZE=5
SISGES_DATABASE_MAX_OVERFLOW=10
SISGES_DATABASE_POOL_RECYCLE_SECONDS=1800
SISGES_DATABASE_POOL_PRE_PING=true
SISGES_SECRET_KEY=change-this-local-secret
SISGES_VAULT_KEY=change-this-local-vault-key-different-from-secret
SISGES_FRONTEND_ORIGINS=

SISGES_SESSION_COOKIE_NAME=session_token
# Em SISGES_ENV=prod, o backend exige cookie Secure=true e SameSite=strict.
SISGES_SESSION_COOKIE_SECURE=false
SISGES_SESSION_COOKIE_SAMESITE=lax
SISGES_SESSION_COOKIE_PATH=/
SISGES_SESSION_MAX_AGE_SECONDS=43200
SISGES_CSRF_ENABLED=false
SISGES_CSRF_COOKIE_NAME=csrf_token
SISGES_CSRF_HEADER_NAME=X-CSRF-Token
SISGES_LOG_LEVEL=INFO
SISGES_LOG_FORMAT=json
SISGES_WORKSPACE_RETENTION_HOURS=24

# Optional bootstrap admin. Leave password empty unless you want seed to create/update it.
SISGES_BOOTSTRAP_ADMIN_USERNAME=admin
SISGES_BOOTSTRAP_ADMIN_PASSWORD=
SISGES_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin SisGeS
SISGES_BOOTSTRAP_ADMIN_EMAIL=admin@sisges.local
SISGES_BOOTSTRAP_ADMIN_ROLES=admin
SISGES_BOOTSTRAP_ADMIN_IS_DEV=false
